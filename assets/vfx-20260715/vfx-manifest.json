  "routing": [
    {
      "when": "e.t === 'dmg' && e.tag === '攻击'，且源 fighter 的 tg !== 'pierce'",
      "play": [
        "slash（按敌我方向选行）",
        "impact"
      ]
    },
    {
      "when": "e.t === 'dmg' && e.tag === '攻击'，且源 fighter 的 tg === 'pierce'",
      "play": [
        "pierce（从 sourceAnchor 飞到 targetAnchor）",
        "impact"
      ],
      "note": "e.eff 是四象伤害倍率，不是穿透标记；穿透须由 e.s 反查 fighter.tg。"
    },
    {
      "when": "e.t === 'dmg' && e.tag !== '攻击'",
      "play": [
        "impact"
      ],
      "note": "技能伤害不叠斩击，避免视觉误导。"
    },
    {
      "when": "e.t === 'dmg' && e.crit === true",
      "play": [
        "critical"
      ],
      "note": "与本次伤害的基础命中特效叠加。"
    },
    {
      "when": "e.t === 'die'",
      "play": [
        "death"
      ],
      "critical": "死亡碎散必须绑定 die，绝不能绑定 dmg.kill。kill=true 之后可能进入 revive 或 shed，尚未真正阵亡。"
    },
    {
      "when": "e.t === 'shieldHit'",
      "play": [
        "shieldHit"
      ],
      "critical": "当前事件只给出本次吸收量，没有剩余护盾值；语义应为护盾受击/裂痕，不应承诺护盾已破。"
    },
    {
      "when": "e.t === 'heal'",
      "play": [
        "heal"
      ]
    },
    {
      "when": "e.t === 'shed'",
      "play": [
        "shed"
      ],
      "note": "蛇蜕是复起分支，应先移除 dead 残留，再播紫雾。"
    }
  ],
